rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Single-user app — only the authorized user can read/write
    // Replace with your actual Google account email
    function isAuthorized() {
      return request.auth != null &&
             request.auth.token.email == 'rikesh@debugdream.com';
    }

    // All collections — only accessible to the authorized user
    match /{collection}/{document=**} {
      allow read, write: if isAuthorized();
    }
  }
}
